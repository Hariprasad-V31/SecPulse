# ---------------------------------------------------------------------------
# SecPulse environment configuration
# Copy this file to `.env.local` and fill in your values.
# ---------------------------------------------------------------------------

# GitHub Models access token (a GitHub PAT with the "models" permission).
# Create one at: https://github.com/settings/tokens
# If left empty, SecPulse automatically falls back to the built-in local
# rule-based anomaly engine — the app stays fully functional without a key.
GITHUB_TOKEN=

# (Optional) Override the GitHub Models inference endpoint.
# Default: https://models.github.ai/inference/chat/completions
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference/chat/completions

# (Optional) Override the model used for anomaly analysis.
# Default: openai/gpt-4o
GITHUB_MODEL=openai/gpt-4o
